# ez2claude environment variables
# Copy this file to `.env` (never commit .env) and fill in your own values.
# Claude Code reads these when installed via install.sh.

# Google Gemini API key for the gemini-mcp bridge.
# Get one at: https://aistudio.google.com/apikey
# Leave blank to disable Gemini multimodal tools.
GEMINI_API_KEY=

# Minimum release age (days) for npm/pnpm/bun packages.
# New releases younger than this are blocked by the supply-chain hook.
# Default: 3 days. Raise to 7 for stricter protection.
NPM_MIN_RELEASE_AGE_DAYS=3
